# 1. Google Gemini API Key
# Get your key from: https://aistudio.google.com/
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# 2. Google Maps Platform API Key
# Required for location and coordinate mapping
# Get your key from: https://console.cloud.google.com/google/maps-apis/
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# 3. Google Weather / OpenWeather API Key
# Required for environmental suitability analysis
GOOGLE_WEATHER_API_KEY=YOUR_WEATHER_API_KEY_HERE

# 4. Optional: GCP Vertex AI Configuration
# Uncomment and fill if you prefer using Vertex AI backend
# GCP_PROJECT=your-project-id
# GCP_LOCATION=us-central1

# 5. GitHub Bot Account for SEO Site Publisher
# Create a GitHub bot account and generate a PAT (see SETUP.md)
GITHUB_BOT_TOKEN=YOUR_GITHUB_BOT_TOKEN_HERE
GITHUB_BOT_USERNAME=YOUR_GITHUB_BOT_USERNAME_HERE
GITHUB_BOT_EMAIL=YOUR_GITHUB_BOT_EMAIL_HERE
