# Google Maps API Key for address autocompletion
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Backend URL — used for BOTH local dev and Firebase production.
# For local dev, the frontend will try this URL first, then fallback to localhost:8000.
# For Firebase production, this URL is baked into the build.
VITE_API_URL=your_vite_api_url_here