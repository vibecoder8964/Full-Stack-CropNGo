# 1. Google Gemini API Key (Mandatory)
# Get your key from: https://aistudio.google.com/
GEMINI_API_KEY= ENTER_YOUR_GEMINI_API_KEY_HERE

# 2. Google Maps Platform API Key (Optional)
# Required for location and coordinate mapping
# Get your key from: https://console.cloud.google.com/google/maps-apis/
GOOGLE_MAPS_API_KEY= ENTER_YOUR_GOOGLE_MAPS_API_KEY_HERE

# 3. Google Weather / OpenWeather API Key (Optional)
# Required for environmental suitability analysis
GOOGLE_WEATHER_API_KEY=ENTER_YOUR_WEATHER_API_KEY_HERE

# 4. Firebase Backend (Optional)
# IMPORTANT: If pasting JSON here, put it on ONE LINE and wrap in single quotes '...'
# Or just put 'firebase-key.json' in this folder and the app will find it automatically!
FIREBASE_CREDENTIALS_JSON='{"type": "service_account", ...}'
 
# 5. GitHub Bot Account for SEO Site Publisher (Optional)
# Create a GitHub bot account and generate a PAT (see SETUP.md)
GITHUB_BOT_TOKEN= ENTER_YOUR_GITHUB_BOT_TOKEN_HERE
GITHUB_BOT_USERNAME= ENTER_YOUR_GITHUB_BOT_USERNAME_HERE
GITHUB_BOT_EMAIL= ENTER_YOUR_GITHUB_BOT_EMAIL_HERE

# 6. Future upgrades (now does not require this): GCP Vertex AI Configuration
# GCP_PROJECT=your-project-id
# GCP_LOCATION=us-central1